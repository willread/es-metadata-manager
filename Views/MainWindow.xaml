<Window x:Class="GamelistScraper.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:GamelistScraper.ViewModels"
        Title="ES Metadata Manager — ScreenScraper for ES-DE / EmulationStation"
        Width="1000" Height="700"
        WindowStartupLocation="CenterScreen"
        Background="#1e1e2e">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#cdd6f4"/>
        </Style>
        <Style TargetType="Label">
            <Setter Property="Foreground" Value="#cdd6f4"/>
        </Style>
        <Style x:Key="HeaderText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#89b4fa"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#45475a"/>
            <Setter Property="Foreground" Value="#cdd6f4"/>
            <Setter Property="BorderBrush" Value="#585b70"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#89b4fa"/>
            <Setter Property="Foreground" Value="#1e1e2e"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#f38ba8"/>
            <Setter Property="Foreground" Value="#1e1e2e"/>
        </Style>
        <Style TargetType="TabItem">
            <Setter Property="Foreground" Value="#bac2de"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#cdd6f4"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#313244"/>
            <Setter Property="Foreground" Value="#cdd6f4"/>
            <Setter Property="BorderBrush" Value="#45475a"/>
            <Setter Property="Padding" Value="4,2"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#313244"/>
            <Setter Property="Foreground" Value="#cdd6f4"/>
            <Setter Property="BorderBrush" Value="#45475a"/>
        </Style>
        <Style TargetType="PasswordBox">
            <Setter Property="Background" Value="#313244"/>
            <Setter Property="Foreground" Value="#cdd6f4"/>
            <Setter Property="BorderBrush" Value="#45475a"/>
            <Setter Property="Padding" Value="4,2"/>
        </Style>
    </Window.Resources>

    <Grid>
        <TabControl Background="#181825" BorderBrush="#313244">
            <!-- TAB 1: Systems -->
            <TabItem Header="  Systems  ">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Top bar -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                        <Button Content="Load Systems" Command="{Binding LoadSystemsCommand}"
                                Style="{StaticResource PrimaryButton}" Margin="0,0,8,0"/>
                        <Button Content="Select All" Command="{Binding SelectAllCommand}" Margin="0,0,4,0"/>
                        <Button Content="Deselect All" Command="{Binding DeselectAllCommand}" Margin="0,0,16,0"/>
                        <TextBox Width="200" Text="{Binding SystemFilter, UpdateSourceTrigger=PropertyChanged}"
                                 VerticalContentAlignment="Center"/>
                        <TextBlock Text="  Filter systems" VerticalAlignment="Center" Foreground="#6c7086"/>
                    </StackPanel>

                    <!-- Cache info bar -->
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="{Binding NotFoundCacheCount, StringFormat='Not-found cache: {0} games'}"
                                   Foreground="#fab387" Margin="0,0,16,0" VerticalAlignment="Center"/>
                        <Button Content="Clear Not-Found" Command="{Binding ClearNotFoundCacheCommand}"
                                FontSize="11" Padding="8,3" Margin="0,0,16,0"/>
                        <TextBlock Text="{Binding ErrorCacheCount, StringFormat='Error cache: {0} games'}"
                                   Foreground="#f38ba8" Margin="0,0,16,0" VerticalAlignment="Center"/>
                        <Button Content="Clear Errors (Retry)" Command="{Binding ClearErrorCacheCommand}"
                                FontSize="11" Padding="8,3"/>
                    </StackPanel>

                    <!-- Systems list + detail -->
                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="350"/>
                        </Grid.ColumnDefinitions>

                        <!-- System list -->
                        <ListBox Grid.Column="0" ItemsSource="{Binding FilteredSystems}"
                                 SelectedItem="{Binding SelectedSystem}"
                                 Background="#181825" BorderBrush="#313244"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="4,2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected}"
                                                  VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="{Binding FullName}" FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding Name}" Foreground="#6c7086" FontSize="11"/>
                                        </StackPanel>
                                        <TextBlock Grid.Column="2" Text="{Binding StatusText}"
                                                   Foreground="#a6adc8" VerticalAlignment="Center" Margin="8,0"/>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <!-- Media config for selected system -->
                        <Border Grid.Column="1" Background="#11111b" BorderBrush="#313244"
                                BorderThickness="1" Margin="8,0,0,0" Padding="12">
                            <StackPanel>
                                <TextBlock Style="{StaticResource HeaderText}"
                                           Text="{Binding SelectedSystem.FullName, FallbackValue='Select a system'}"/>
                                <TextBlock Text="Media Types (check = download, uncheck = skip)"
                                           Foreground="#6c7086" FontSize="11" Margin="0,0,0,8"/>

                                <ItemsControl ItemsSource="{Binding SelectedSystem.MediaToggles}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,2">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <CheckBox Grid.Column="0" IsChecked="{Binding IsEnabled}"
                                                          VerticalAlignment="Center"/>
                                                <TextBlock Grid.Column="1" Text="{Binding DisplayName}"
                                                           VerticalAlignment="Center" Margin="6,0"/>
                                                <TextBlock Grid.Column="2"
                                                           Text="{Binding FileCount, StringFormat='{}{0} files'}"
                                                           Foreground="#6c7086" FontSize="11"
                                                           VerticalAlignment="Center" Margin="4,0"/>
                                                <TextBlock Grid.Column="3" Text="(override)"
                                                           Foreground="#fab387" FontSize="10"
                                                           Visibility="{Binding IsOverridden, Converter={StaticResource BoolToVis}}"
                                                           VerticalAlignment="Center" Margin="4,0"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <Separator Margin="0,12" Background="#313244"/>

                                <Button Content="Cleanup Disabled Media for Selected Systems"
                                        Command="{Binding DataContext.CleanupMediaCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        Style="{StaticResource DangerButton}" FontSize="11"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- TAB 2: Scrape -->
            <TabItem Header="  Scrape  ">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Controls -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
                        <Button Content="Start Scrape" Command="{Binding StartScrapeCommand}"
                                Style="{StaticResource PrimaryButton}" Margin="0,0,8,0"
                                IsEnabled="{Binding IsLoaded}"/>
                        <Button Content="Stop" Command="{Binding StopScrapeCommand}"
                                Style="{StaticResource DangerButton}"
                                Visibility="{Binding IsScraping, Converter={StaticResource BoolToVis}}"/>
                    </StackPanel>

                    <!-- API Quota -->
                    <Border Grid.Row="0" Background="#11111b" CornerRadius="4" Padding="8" Margin="0,0,0,0"
                            HorizontalAlignment="Right"
                            Visibility="{Binding IsScraping, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="{Binding ApiQuotaText}" Foreground="#f9e2af" FontSize="12"/>
                    </Border>

                    <!-- Progress -->
                    <StackPanel Grid.Row="1" Margin="0,0,0,16">
                        <TextBlock Text="{Binding ProgressText}" FontSize="13" Margin="0,0,0,4"/>
                        <ProgressBar Value="{Binding ProgressPercent}" Height="20"
                                     Background="#313244" Foreground="#89b4fa" BorderBrush="#45475a"/>
                        <Grid Margin="0,4,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0">
                                <Run Text="System: " Foreground="#6c7086"/>
                                <Run Text="{Binding CurrentSystem, Mode=OneWay}"/>
                            </TextBlock>
                            <TextBlock Grid.Column="1">
                                <Run Text="Game: " Foreground="#6c7086"/>
                                <Run Text="{Binding CurrentGame, Mode=OneWay}"/>
                            </TextBlock>
                        </Grid>
                    </StackPanel>

                    <!-- Stats -->
                    <Border Grid.Row="2" Background="#11111b" CornerRadius="4" Padding="16" Margin="0,0,0,16">
                        <WrapPanel>
                            <StackPanel Margin="0,0,32,0">
                                <TextBlock Text="Scraped" Foreground="#6c7086" FontSize="11"/>
                                <TextBlock Text="{Binding StatScraped}" FontSize="24" Foreground="#a6e3a1" FontWeight="Bold"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,32,0">
                                <TextBlock Text="Not Found" Foreground="#6c7086" FontSize="11"/>
                                <TextBlock Text="{Binding StatNotFound}" FontSize="24" Foreground="#fab387" FontWeight="Bold"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,32,0">
                                <TextBlock Text="Errors" Foreground="#6c7086" FontSize="11"/>
                                <TextBlock Text="{Binding StatErrors}" FontSize="24" Foreground="#f38ba8" FontWeight="Bold"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,32,0">
                                <TextBlock Text="Skipped" Foreground="#6c7086" FontSize="11"/>
                                <TextBlock Text="{Binding StatSkipped}" FontSize="24" Foreground="#6c7086" FontWeight="Bold"/>
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="Media Files" Foreground="#6c7086" FontSize="11"/>
                                <TextBlock Text="{Binding StatMedia}" FontSize="24" Foreground="#89b4fa" FontWeight="Bold"/>
                            </StackPanel>
                        </WrapPanel>
                    </Border>
                </Grid>
            </TabItem>

            <!-- TAB 3: Log -->
            <TabItem Header="  Log  ">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                        <ComboBox Width="100" SelectedItem="{Binding Log.FilterLevel}">
                            <ComboBoxItem Content="All"/>
                            <ComboBoxItem Content="Warning"/>
                            <ComboBoxItem Content="Error"/>
                        </ComboBox>
                        <Button Content="Clear" Command="{Binding Log.ClearCommand}" Margin="8,0"/>
                        <Button Content="Export" Command="{Binding Log.ExportLogCommand}" Margin="0,0,0,0"/>
                    </StackPanel>
                    <ListBox Grid.Row="1" ItemsSource="{Binding Log.FilteredEntries}"
                             Background="#11111b" BorderBrush="#313244"
                             FontFamily="Cascadia Mono, Consolas, Courier New"
                             FontSize="12">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Display}" TextWrapping="Wrap" Foreground="#cdd6f4"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </TabItem>

            <!-- TAB 4: Settings -->
            <TabItem Header="  Settings  ">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="16" MaxWidth="600">
                        <!-- Frontend -->
                        <TextBlock Style="{StaticResource HeaderText}" Text="Frontend"/>
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition/>
                                <RowDefinition/>
                                <RowDefinition/>
                                <RowDefinition/>
                            </Grid.RowDefinitions>
                            <Label Grid.Row="0" Grid.Column="0" Content="Type:"/>
                            <ComboBox Grid.Row="0" Grid.Column="1" SelectedItem="{Binding Settings.FrontendType}"
                                      ItemsSource="{Binding Settings.FrontendTypes}" Margin="0,2"/>
                            <Button Grid.Row="0" Grid.Column="2" Content="Auto-detect"
                                    Command="{Binding Settings.AutoDetectCommand}" Margin="8,2,0,2"/>

                            <Label Grid.Row="1" Grid.Column="0" Content="Config path:"/>
                            <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding Settings.ConfigPath}" Margin="0,2"/>
                            <Button Grid.Row="1" Grid.Column="2" Content="Browse"
                                    Command="{Binding Settings.BrowseConfigPathCommand}" Margin="8,2,0,2"/>

                            <Label Grid.Row="2" Grid.Column="0" Content="ROM directory:"/>
                            <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding Settings.RomDirectory}" Margin="0,2"/>
                            <Button Grid.Row="2" Grid.Column="2" Content="Browse"
                                    Command="{Binding Settings.BrowseRomDirectoryCommand}" Margin="8,2,0,2"/>

                            <Label Grid.Row="3" Grid.Column="0" Content="Media directory:"/>
                            <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding Settings.MediaDirectory}" Margin="0,2"/>
                            <Button Grid.Row="3" Grid.Column="2" Content="Browse"
                                    Command="{Binding Settings.BrowseMediaDirectoryCommand}" Margin="8,2,0,2"/>
                        </Grid>

                        <!-- ScreenScraper Credentials -->
                        <TextBlock Style="{StaticResource HeaderText}" Text="ScreenScraper Credentials"/>
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition/>
                                <RowDefinition/>
                            </Grid.RowDefinitions>
                            <Label Grid.Row="0" Content="Username:"/>
                            <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding Settings.ScreenScraperUser}" Margin="0,2"/>
                            <Label Grid.Row="1" Content="Password:"/>
                            <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding Settings.ScreenScraperPassword}" Margin="0,2"/>
                            <Button Grid.Row="1" Grid.Column="2" Content="Test"
                                    Command="{Binding Settings.TestCredentialsCommand}" Margin="8,2,0,2"/>
                        </Grid>

                        <!-- Global Media Types -->
                        <TextBlock Style="{StaticResource HeaderText}" Text="Default Media Types (Global)"/>
                        <TextBlock Text="These apply to all systems unless overridden per-system in the Systems tab."
                                   Foreground="#6c7086" FontSize="11" Margin="0,0,0,8"/>
                        <ItemsControl ItemsSource="{Binding Settings.GlobalMediaToggles}" Margin="0,0,0,16">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding IsEnabled}" Content="{Binding DisplayName}"
                                              Margin="0,3"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Scraping Options -->
                        <TextBlock Style="{StaticResource HeaderText}" Text="Scraping Options"/>
                        <StackPanel Margin="0,0,0,16">
                            <CheckBox Content="Force re-scrape already scraped games"
                                      IsChecked="{Binding Settings.ForceRescrape}" Margin="0,3"/>
                            <CheckBox Content="Force re-download existing media"
                                      IsChecked="{Binding Settings.ForceRedownloadMedia}" Margin="0,3"/>
                            <Grid Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition/>
                                    <RowDefinition/>
                                </Grid.RowDefinitions>
                                <Label Grid.Row="0" Content="Region:"/>
                                <ComboBox Grid.Row="0" Grid.Column="1" Width="100" HorizontalAlignment="Left"
                                          SelectedItem="{Binding Settings.PreferredRegion}"
                                          ItemsSource="{Binding Settings.Regions}" Margin="0,2"/>
                                <Label Grid.Row="1" Content="Language:"/>
                                <ComboBox Grid.Row="1" Grid.Column="1" Width="100" HorizontalAlignment="Left"
                                          SelectedItem="{Binding Settings.PreferredLanguage}"
                                          ItemsSource="{Binding Settings.Languages}" Margin="0,2"/>
                            </Grid>
                        </StackPanel>

                        <!-- Save -->
                        <StackPanel Orientation="Horizontal">
                            <Button Content="Save Settings" Command="{Binding Settings.SaveCommand}"
                                    Style="{StaticResource PrimaryButton}" Margin="0,0,16,0"/>
                            <TextBlock Text="{Binding Settings.StatusMessage}" VerticalAlignment="Center"
                                       Foreground="#a6e3a1"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
