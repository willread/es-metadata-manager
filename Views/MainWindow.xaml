<Window x:Class="GamelistScraper.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:GamelistScraper.ViewModels"
        Title="ES Metadata Manager"
        Width="960" Height="700"
        MinWidth="800" MinHeight="550"
        WindowStartupLocation="CenterScreen"
        Background="#1e1e2e">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- Base text -->
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#cdd6f4"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style TargetType="Label">
            <Setter Property="Foreground" Value="#a6adc8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="0,4"/>
        </Style>

        <!-- Section headers -->
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#a6adc8"/>
            <Setter Property="Margin" Value="0,16,0,8"/>
        </Style>

        <!-- Buttons -->
        <Style TargetType="Button">
            <Setter Property="Background" Value="#313244"/>
            <Setter Property="Foreground" Value="#cdd6f4"/>
            <Setter Property="BorderBrush" Value="#45475a"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#45475a"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.4"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="AccentButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#89b4fa"/>
            <Setter Property="Foreground" Value="#1e1e2e"/>
            <Setter Property="BorderBrush" Value="#89b4fa"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#74c7ec"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#f38ba8"/>
            <Setter Property="Foreground" Value="#1e1e2e"/>
            <Setter Property="BorderBrush" Value="#f38ba8"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#eba0ac"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="SmallButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>

        <!-- Inputs -->
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#313244"/>
            <Setter Property="Foreground" Value="#cdd6f4"/>
            <Setter Property="BorderBrush" Value="#45475a"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="CaretBrush" Value="#cdd6f4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="0"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="PasswordBox">
            <Setter Property="Background" Value="#313244"/>
            <Setter Property="Foreground" Value="#cdd6f4"/>
            <Setter Property="BorderBrush" Value="#45475a"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="CaretBrush" Value="#cdd6f4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="0"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- ComboBox toggle button (the main clickable area) -->
        <ControlTemplate x:Key="ComboBoxToggleButton" TargetType="ToggleButton">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="20"/>
                </Grid.ColumnDefinitions>
                <Border x:Name="Border" Grid.ColumnSpan="2" Background="#313244"
                        BorderBrush="#45475a" BorderThickness="1" CornerRadius="4"/>
                <Path x:Name="Arrow" Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center"
                      Data="M0,0 L4,4 8,0" Stroke="#a6adc8" StrokeThickness="1.5" Fill="Transparent"/>
            </Grid>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="Border" Property="Background" Value="#45475a"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>
        <Style TargetType="ComboBox">
            <Setter Property="Foreground" Value="#cdd6f4"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton Template="{StaticResource ComboBoxToggleButton}"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          Focusable="False" ClickMode="Press"/>
                            <ContentPresenter x:Name="ContentSite" IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              Margin="8,4,24,4" VerticalAlignment="Center"
                                              HorizontalAlignment="Left"/>
                            <Popup x:Name="Popup" Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                                <Grid x:Name="DropDown" SnapsToDevicePixels="True"
                                      MinWidth="{TemplateBinding ActualWidth}" MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <Border x:Name="DropDownBorder" Background="#313244"
                                            BorderBrush="#45475a" BorderThickness="1" CornerRadius="4"
                                            Margin="0,2,0,0"/>
                                    <ScrollViewer Margin="4,6,4,6" SnapsToDevicePixels="True">
                                        <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Grid>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="#cdd6f4"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Bd" Background="Transparent"
                                Padding="{TemplateBinding Padding}" CornerRadius="3">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#45475a"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#45475a"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#cdd6f4"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,2"/>
        </Style>

        <!-- Tabs -->
        <Style TargetType="TabItem">
            <Setter Property="Foreground" Value="#6c7086"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="Border" Padding="{TemplateBinding Padding}"
                                BorderThickness="0,0,0,2" BorderBrush="Transparent"
                                Background="Transparent" Cursor="Hand">
                            <ContentPresenter ContentSource="Header"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="#89b4fa"/>
                                <Setter Property="Foreground" Value="#cdd6f4"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#bac2de"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <TabControl x:Name="MainTabControl" Background="#1e1e2e" BorderThickness="0" Padding="0">
        <!-- ════════════════ SCRAPE TAB ════════════════ -->
        <TabItem Header="Scrape">
            <Grid Margin="20,16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*" MinHeight="120"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="140"/>
                </Grid.RowDefinitions>

                <!-- Row 0: Toolbar -->
                <DockPanel Grid.Row="0" Margin="0,0,0,10">
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                        <Button Content="Start Scrape" Command="{Binding StartScrapeCommand}"
                                Style="{StaticResource AccentButton}" IsEnabled="{Binding IsLoaded}"
                                Visibility="{Binding NotScraping, Converter={StaticResource BoolToVis}}"
                                Margin="0,0,6,0"/>
                        <Button Content="Stop" Command="{Binding StopScrapeCommand}"
                                Style="{StaticResource DangerButton}"
                                Visibility="{Binding IsScraping, Converter={StaticResource BoolToVis}}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Button Content="All" Command="{Binding SelectAllCommand}"
                                Style="{StaticResource SmallButton}" Margin="0,0,4,0"
                                IsEnabled="{Binding NotScraping}"/>
                        <Button Content="None" Command="{Binding DeselectAllCommand}"
                                Style="{StaticResource SmallButton}" Margin="0,0,12,0"
                                IsEnabled="{Binding NotScraping}"/>
                        <Grid Width="200">
                            <TextBox x:Name="FilterBox" Text="{Binding SystemFilter, UpdateSourceTrigger=PropertyChanged}"
                                     VerticalContentAlignment="Center"/>
                            <TextBlock Text="Filter systems..." Foreground="#585b70" FontSize="12"
                                       IsHitTestVisible="False" VerticalAlignment="Center" Margin="10,0,0,0">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Text, ElementName=FilterBox}" Value="">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </StackPanel>
                </DockPanel>

                <!-- Row 1: System list -->
                <ListBox Grid.Row="1" ItemsSource="{Binding FilteredSystems}"
                         SelectedItem="{Binding SelectedSystem}"
                         Background="#181825" BorderBrush="#313244" BorderThickness="1"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         Padding="2">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Foreground" Value="#cdd6f4"/>
                            <Setter Property="Padding" Value="8,5"/>
                            <Setter Property="Margin" Value="0"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                                Padding="{TemplateBinding Padding}" CornerRadius="4"
                                                Margin="2,1">
                                            <ContentPresenter/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#1f1f30"/>
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#252538"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected}"
                                          VerticalAlignment="Center" Margin="0,0,10,0"
                                          Foreground="#cdd6f4"
                                          IsEnabled="{Binding DataContext.NotScraping, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                <TextBlock Grid.Column="1" Text="{Binding FullName}"
                                           Foreground="#cdd6f4"
                                           VerticalAlignment="Center" FontSize="13"/>
                                <TextBlock Grid.Column="2" Text="{Binding StatusText}"
                                           Foreground="#585b70" VerticalAlignment="Center"
                                           FontSize="11" Margin="12,0,0,0"/>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!-- Row 2: Progress section -->
                <Grid Grid.Row="2" Margin="0,12,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Progress label row -->
                    <DockPanel Grid.Row="0" Margin="0,0,0,4">
                        <TextBlock DockPanel.Dock="Right" Text="{Binding ApiQuotaText}"
                                   Foreground="#f9e2af" FontSize="11"/>
                        <TextBlock Text="{Binding ProgressText}" FontSize="12" Foreground="#a6adc8"/>
                    </DockPanel>

                    <!-- Progress bar -->
                    <ProgressBar Grid.Row="1" Value="{Binding ProgressPercent}" Height="8"
                                 Background="#313244" Foreground="#89b4fa" BorderThickness="0"/>

                    <!-- Current item -->
                    <TextBlock Grid.Row="2" Margin="0,4,0,0" FontSize="11" Foreground="#585b70">
                        <Run Text="{Binding CurrentSystem, Mode=OneWay}"/>
                        <Run Text=" — "/>
                        <Run Text="{Binding CurrentGame, Mode=OneWay}"/>
                    </TextBlock>
                </Grid>

                <!-- Row 3: Stats -->
                <Border Grid.Row="3" Background="#181825" CornerRadius="6" Padding="16,10" Margin="0,10,0,0"
                        BorderBrush="#313244" BorderThickness="1">
                    <UniformGrid Columns="5">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="{Binding StatScraped}" FontSize="22" Foreground="#a6e3a1"
                                       FontWeight="Bold" HorizontalAlignment="Center"/>
                            <TextBlock Text="Scraped" Foreground="#585b70" FontSize="10"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="{Binding StatNotFound}" FontSize="22" Foreground="#fab387"
                                       FontWeight="Bold" HorizontalAlignment="Center"/>
                            <TextBlock Text="Not Found" Foreground="#585b70" FontSize="10"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="{Binding StatErrors}" FontSize="22" Foreground="#f38ba8"
                                       FontWeight="Bold" HorizontalAlignment="Center"/>
                            <TextBlock Text="Errors" Foreground="#585b70" FontSize="10"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="{Binding StatSkipped}" FontSize="22" Foreground="#6c7086"
                                       FontWeight="Bold" HorizontalAlignment="Center"/>
                            <TextBlock Text="Skipped" Foreground="#585b70" FontSize="10"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="{Binding StatMedia}" FontSize="22" Foreground="#89b4fa"
                                       FontWeight="Bold" HorizontalAlignment="Center"/>
                            <TextBlock Text="Media" Foreground="#585b70" FontSize="10"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </UniformGrid>
                </Border>

                <!-- Row 4: Log header -->
                <DockPanel Grid.Row="4" Margin="0,10,0,4">
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                        <Button Content="Clear" Command="{Binding Log.ClearCommand}"
                                Style="{StaticResource SmallButton}" Margin="0,0,4,0"/>
                        <Button Content="Export" Command="{Binding Log.ExportLogCommand}"
                                Style="{StaticResource SmallButton}"/>
                    </StackPanel>
                    <TextBlock Text="Log" Foreground="#a6adc8" FontSize="12" FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                </DockPanel>

                <!-- Row 5: Log output -->
                <ListBox x:Name="LogListBox" Grid.Row="5" ItemsSource="{Binding Log.FilteredEntries}"
                         Background="#11111b" BorderBrush="#313244" BorderThickness="1"
                         FontFamily="Cascadia Mono, Consolas, Courier New"
                         FontSize="11" Padding="4"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="4,1"/>
                            <Setter Property="Margin" Value="0"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <ContentPresenter Margin="{TemplateBinding Padding}"/>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Display}" TextWrapping="Wrap" Foreground="#a6adc8"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </TabItem>

        <!-- ════════════════ SETTINGS TAB ════════════════ -->
        <TabItem Header="Settings">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0">
                <StackPanel Margin="20,16" MaxWidth="560">

                    <!-- Frontend -->
                    <TextBlock Text="FRONTEND" Style="{StaticResource SectionHeader}" Margin="0,0,0,8"/>
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Label Content="Type"/>
                        <ComboBox Grid.Column="1" SelectedItem="{Binding Settings.FrontendType}"
                                  ItemsSource="{Binding Settings.FrontendTypes}" Margin="0,0,8,0"/>
                        <Button Grid.Column="2" Content="Auto-detect"
                                Command="{Binding Settings.AutoDetectCommand}"
                                Style="{StaticResource SmallButton}"/>
                    </Grid>
                    <Grid Margin="0,4,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Label Content="Config path"/>
                        <TextBox Grid.Column="1" Text="{Binding Settings.ConfigPath}" Margin="0,0,8,0"/>
                        <Button Grid.Column="2" Content="Browse"
                                Command="{Binding Settings.BrowseConfigPathCommand}"
                                Style="{StaticResource SmallButton}"/>
                    </Grid>
                    <TextBlock Text="{Binding Settings.DetectedConfigInfo, Mode=OneWay}"
                               Foreground="#a6e3a1" FontSize="11" Margin="100,2,0,0"/>

                    <!-- Credentials -->
                    <TextBlock Text="SCREENSCRAPER ACCOUNT" Style="{StaticResource SectionHeader}"/>
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Label Grid.Row="0" Content="Username"/>
                        <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding Settings.ScreenScraperUser}"
                                 Margin="0,0,8,4"/>

                        <Label Grid.Row="1" Content="Password"/>
                        <PasswordBox Grid.Row="1" Grid.Column="1" x:Name="PasswordField"
                                     PasswordChanged="PasswordField_PasswordChanged"
                                     Margin="0,0,8,0"/>
                        <Button Grid.Row="1" Grid.Column="2" Content="Test"
                                Command="{Binding Settings.TestCredentialsCommand}"
                                Style="{StaticResource SmallButton}"/>
                    </Grid>
                    <TextBlock Text="{Binding Settings.StatusMessage}" Foreground="#a6e3a1"
                               FontSize="11" Margin="100,2,0,0"/>

                    <!-- Content to scrape -->
                    <TextBlock Text="CONTENT" Style="{StaticResource SectionHeader}"/>
                    <CheckBox Content="Metadata (name, description, genre, etc.)"
                              IsChecked="{Binding Settings.ScrapeMetadata}" Margin="0,0,0,8" FontSize="12"/>
                    <ItemsControl ItemsSource="{Binding Settings.GlobalMediaToggles}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <CheckBox IsChecked="{Binding IsEnabled}" Content="{Binding DisplayName}"
                                          Margin="0,3,24,3" FontSize="12"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Scraping Options -->
                    <TextBlock Text="SCRAPING OPTIONS" Style="{StaticResource SectionHeader}"/>
                    <CheckBox Content="Force re-scrape already scraped games"
                              IsChecked="{Binding Settings.ForceRescrape}"/>
                    <CheckBox Content="Force re-download existing media"
                              IsChecked="{Binding Settings.ForceRedownloadMedia}"/>
                    <Grid Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition/>
                            <RowDefinition/>
                        </Grid.RowDefinitions>
                        <Label Grid.Row="0" Content="Region"/>
                        <ComboBox Grid.Row="0" Grid.Column="1" Width="90"
                                  SelectedItem="{Binding Settings.PreferredRegion}"
                                  ItemsSource="{Binding Settings.Regions}" Margin="0,2"/>
                        <Label Grid.Row="1" Content="Language"/>
                        <ComboBox Grid.Row="1" Grid.Column="1" Width="90"
                                  SelectedItem="{Binding Settings.PreferredLanguage}"
                                  ItemsSource="{Binding Settings.Languages}" Margin="0,2"/>
                    </Grid>

                    <!-- Cache & Cleanup -->
                    <TextBlock Text="CACHE &amp; CLEANUP" Style="{StaticResource SectionHeader}"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <TextBlock Foreground="#fab387" FontSize="12" VerticalAlignment="Center"
                                   Text="{Binding NotFoundCacheCount, StringFormat='Not-found: {0}'}"/>
                        <Button Content="Clear" Command="{Binding ClearNotFoundCacheCommand}"
                                Style="{StaticResource SmallButton}" Margin="10,0,0,0"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <TextBlock Foreground="#f38ba8" FontSize="12" VerticalAlignment="Center"
                                   Text="{Binding ErrorCacheCount, StringFormat='API errors: {0}'}"/>
                        <Button Content="Clear (Retry)" Command="{Binding ClearErrorCacheCommand}"
                                Style="{StaticResource SmallButton}" Margin="10,0,0,0"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <TextBlock Foreground="#eba0ac" FontSize="12" VerticalAlignment="Center"
                                   Text="{Binding MediaErrorCount, StringFormat='Media download errors: {0}'}"/>
                        <Button Content="Clear (Retry)" Command="{Binding ClearMediaErrorsCommand}"
                                Style="{StaticResource SmallButton}" Margin="10,0,0,0"/>
                    </StackPanel>
                    <Button Content="Clean Up Unselected Media" Command="{Binding CleanupMediaCommand}"
                            Style="{StaticResource DangerButton}" HorizontalAlignment="Left"
                            Margin="0,8,0,0"/>
                    <TextBlock Text="Removes downloaded files for unchecked media types."
                               Foreground="#45475a" FontSize="10" Margin="0,4,0,0"/>

                    <!-- Save -->
                    <Separator Background="#313244" Margin="0,20,0,16"/>
                    <Button Content="Save Settings" Command="{Binding Settings.SaveCommand}"
                            Style="{StaticResource AccentButton}" HorizontalAlignment="Left"/>
                </StackPanel>
            </ScrollViewer>
        </TabItem>
    </TabControl>
</Window>
